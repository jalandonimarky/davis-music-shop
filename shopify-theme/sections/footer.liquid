<footer class="site-footer" role="contentinfo">
  <div class="page-width">
    <div class="footer__grid">
      <div>
        <div class="footer__brand">{{ section.settings.brand | default: shop.name }}</div>
        <p class="footer__copy">{{ section.settings.copy }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div class="footer__col" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              <ul>
                {%- for link in linklists[block.settings.menu].links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <div>© {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</div>
      <div>Powered by Shopify</div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand", "label": "Brand", "default": "JMarky's Music Co." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Guitars, keyboards, drums, and stage gear — curated and built by players, for players." }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list", "settings": { "heading": "Shop" } },
      { "type": "link_list", "settings": { "heading": "Support" } }
    ]
  }
}
{% endschema %}
