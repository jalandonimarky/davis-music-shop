<div class="cart-drawer__backdrop" id="cart-backdrop" data-cart-close></div>
<aside class="cart-drawer" id="cart-drawer" aria-label="Cart">
  <header class="cart-drawer__header">
    <h2 class="cart-drawer__title">Your Cart</h2>
    <button class="cart-drawer__close" data-cart-close aria-label="Close cart">×</button>
  </header>

  <div class="cart-drawer__items" data-cart-items>
    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items -%}
        <div class="cart-line" data-line-key="{{ item.key }}">
          <div class="cart-line__media">
            {%- if item.image != blank -%}
              {{ item.image | image_url: width: 120 | image_tag: alt: item.title, loading: 'lazy' }}
            {%- endif -%}
          </div>
          <div>
            <h4 class="cart-line__title"><a href="{{ item.url }}" style="text-decoration:none;color:inherit">{{ item.product.title }}</a></h4>
            {%- unless item.variant.title contains 'Default' -%}
              <div class="cart-line__variant">{{ item.variant.title }}</div>
            {%- endunless -%}
            <div class="cart-line__controls">
              <span>Qty {{ item.quantity }}</span>
              <a href="{{ item.url_to_remove }}" class="cart-line__remove">Remove</a>
            </div>
          </div>
          <div class="cart-line__price">{{ item.final_line_price | money }}</div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="cart-drawer__empty">
        <p>Your cart is empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary" style="margin-top:14px">Browse instruments</a>
      </div>
    {%- endif -%}
  </div>

  <footer class="cart-drawer__footer" data-cart-footer{% if cart.item_count == 0 %} style="display:none"{% endif %}>
    <div class="cart-drawer__totals">
      <span>Subtotal</span>
      <span data-cart-total>{{ cart.total_price | money }}</span>
    </div>
    <a href="{{ routes.cart_url }}" class="btn btn--primary btn--block">View cart &amp; checkout</a>
    <div class="cart-drawer__note">Shipping &amp; taxes calculated at checkout</div>
  </footer>
</aside>

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
