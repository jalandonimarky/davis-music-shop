<section class="section">
  <div class="page-width">
    <h1>Search</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" style="margin: 20px 0;">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Search instruments…"
        style="padding:12px 16px; border:1px solid var(--color-line); border-radius:999px; min-width:260px;"
      >
      <button type="submit" class="btn btn--primary">Search</button>
    </form>

    {%- if search.performed -%}
      <p>{{ search.results_count }} result{{ search.results_count | pluralize: '', 's' }} for "{{ search.terms | escape }}"</p>

      <div class="product-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'card-product', product: item %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>
