<section class="section">
  <div class="page-width">
    <div class="section__header">
      <h2>Collections</h2>
    </div>
    <div class="product-grid">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="card-product">
          <div class="card-product__media">
            {%- if collection.image != blank -%}
              {{ collection.image | image_url: width: 600 | image_tag: alt: collection.title, loading: 'lazy' }}
            {%- elsif collection.products.first.featured_image != blank -%}
              {{ collection.products.first.featured_image | image_url: width: 600 | image_tag: alt: collection.title, loading: 'lazy' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="card-product__body">
            <h3 class="card-product__title">{{ collection.title }}</h3>
            <div class="card-product__vendor">{{ collection.products_count }} products</div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
